{
  "name": "@boroda/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "mcp": "node --import tsx src/modules/integrations/mcp/stdio.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "npm run lint:types && npm run lint:guardrails",
    "lint:guardrails": "node ../../scripts/quality-gate.mjs packages/server",
    "lint:types": "tsc -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/*.test.ts",
    "migrate": "node --import tsx src/db/migrate.ts",
    "seed": "node --import tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.2.0",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.39.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
